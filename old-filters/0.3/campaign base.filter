    SetTextColor 255 255 255 255
    SetBorderColor 255 255 255 255
    BaseArmour > 0
    BaseEvasion == 0
    BaseEnergyShield == 0

#===============================================================================================================
# Sockets and Quality

Show # large sockets
	Sockets > 1
	Rarity Normal Magic
	Class == "Body Armours" "Bows" "Crossbows" "Quarterstaves" "Two Hand Maces"
    AreaLevel >= 16
	SetFontSize 40
	SetTextColor 102 153 153 255
	SetBorderColor 102 153 153 255
	SetBackgroundColor 80 80 80 168
    CustomAlertSound "socket.ogg" 300

Show # small sockets
	Sockets > 0
	Rarity Normal Magic
	Class == "Boots" "Bucklers" "Gloves" "Helmets" "Spears" "Wands" "Staves"
    AreaLevel >= 16
	SetFontSize 40
	SetTextColor 102 153 153 255
	SetBorderColor 102 153 153 255
	SetBackgroundColor 80 80 80 168
    CustomAlertSound "socket.ogg" 300

Show # weapon and flask quality
	Quality > 0
	Rarity Normal Magic
	Class == "Bows" "Crossbows" "One Hand Maces" "Quarterstaves" "Quivers" "Spears" "Two Hand Maces" "Life Flasks" "Mana Flasks" "Sceptres" "Wands" "Staves"
    AreaLevel >= 16
	SetFontSize 40
	SetTextColor 102 153 153 255
	SetBorderColor 102 153 153 168
	SetBackgroundColor 80 80 80 168
    CustomAlertSound "quality.ogg" 300

#===============================================================================================================
# Hide Gear

Hide # Magic Armour
    Rarity Magic
    AreaLevel >= 16
    Class == "Body Armours" "Boots" "Helmets" "Gloves"
    BaseArmour == 0

Hide # Normal Armour
    Rarity Normal
    AreaLevel >= 2
    Class == "Body Armours" "Boots" "Helmets" "Gloves"
    BaseArmour == 0

Hide # Magic Weapons
    Class == "Wands" "Staves" "Foci" "One Hand Maces" "Quarterstaves" "Two Hand Maces" "Spears" "Bucklers" "Crossbows" "Sceptres" "Bows"
    AreaLevel >= 6
    Rarity Magic

Hide # Normal Weapons
    Class == "Wands" "Staves" "Foci" "One Hand Maces" "Quarterstaves" "Two Hand Maces" "Spears" "Bucklers" "Crossbows" "Sceptres" "Bows"
    AreaLevel >= 2
    Rarity Normal

#===============================================================================================================
# End of Specific Gear
#===============================================================================================================

