#===============================================================================================================
# Hide Gear
Hide # Magic Weapons
    Class == "Crossbows" "Bows" "Quivers" "Bucklers"
    AreaLevel >= 16
    Rarity Magic

Hide # Normal Armour
    Rarity Magic
    AreaLevel >= 6
    Class == "Boots"
    BaseEvasion > 38

Hide # Normal Armour
    Rarity Magic
    AreaLevel >= 6
    Class == "Gloves"
    BaseEvasion > 26

Hide # Magic Armour
    Rarity Magic
    AreaLevel >= 6
    Class == "Body Armours"
    BaseEvasion > 44

Hide # Magic Armour
    Rarity Magic
    AreaLevel >= 6
    Class == "Helmets"
    BaseEvasion > 48

Hide # Normal Armour
    Rarity Normal
    AreaLevel >= 16
    Class == "Body Armours" "Helmets" "Gloves" "Boots"
    BaseEvasion > 0

Hide # Normal Armour
    Rarity Normal
    AreaLevel >= 16
    Class == "Body Armours" "Helmets" "Gloves" "Boots"
    BaseEnergyShield > 0

Hide # Normal Armour
    Rarity Normal
    AreaLevel >= 6
    Class == "Body Armours" "Helmets" "Gloves" "Boots"
    BaseArmour == 0

Hide # Magic Weapons
    Class == "Quarterstaves" "Sceptres" "Shields" "One Hand Maces" "Two Hand Maces" "Bucklers"
    AreaLevel >= 2
    Rarity Magic

Hide # Normal Weapons
    Class == "Quarterstaves" "Spears" "Sceptres" "Bows" "Shields" "Crossbows" "Quivers" "One Hand Maces" "Two Hand Maces" "Talismans" "Bucklers"
    AreaLevel >= 2
    Rarity Normal

